SECRET_KEY=change-me
ADMIN_API_TOKEN=dev-admin-token

# Google Earth Engine (optional — if disabled, analysis uses deterministic simulation)
GEE_ENABLED=false
GEE_PROJECT=
GEE_CREDENTIALS_JSON=

# Twilio SMS (optional)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_TO_NUMBER=
SIMULATE_SMS=true

# Flask-Mail / SMTP (optional)
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@ecoguard.local
SIMULATE_EMAIL=true

# PostgreSQL — same as backend/.env
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/ecoguard